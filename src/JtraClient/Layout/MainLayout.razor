@inherits LayoutComponentBase
@implements IDisposable

<div class="page" @onclick="OnFirstInteraction">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="next-checkin">Next check-in: @FormatNextCheckIn()</span>
            <span class="ms-3">Server: @(AppState.IsConnectedToServer ? "connected" : "disconnected")</span>
            <span class="ms-3">Last tick: @FormatDiagnostic(AppState.LastServerTickReceivedAt, AppState.LastServerTickTime)</span>
            <span class="ms-3">Notification: @FormatNotificationDiagnostic()</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (ShowCheckInPopup)
{
    <EditEntryDialog Entry="checkInEntry"
                     OnSave="HandleCheckInSave"
                     OnDelete="HandleCheckInDelete"
                     OnClose="HandleCancelCheckIn"
                     OnEstimatedEndSelected="HandleEstimatedEndSelected"
                     ShowEstimatedEndOption="true" />
}

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private NotificationService NotificationService { get; set; } = default!;

    private bool ShowCheckInPopup => AppState.ShowCheckInPopup;
    private bool _lastPopupState = false;
    private bool _notificationPermissionRequested = false;
    private TimeEntry checkInEntry = new();

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
    }

    private async Task OnFirstInteraction()
    {
        if (!_notificationPermissionRequested)
        {
            _notificationPermissionRequested = true;
            await NotificationService.RequestPermissionAsync();
        }
    }

    private void OnAppStateChanged()
    {
        if (AppState.ShowCheckInPopup && !_lastPopupState)
        {
            checkInEntry = BuildCheckInEntry();
        }

        if (AppState.ShowCheckInPopup && !_lastPopupState && AppState.IsTimerTriggeredPopup)
        {
            _ = InvokeAsync(ShowCheckInNotification);
        }

        _lastPopupState = AppState.ShowCheckInPopup;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ShowCheckInNotification()
    {
        await NotificationService.ShowNotificationAsync("JTRA Worklog", "Do you want to log a new Task?");
    }

    private async Task HandleCheckInSave(TimeEntry entry)
    {
        await AppState.ConfirmCheckIn(entry.StartTime, entry.Type, entry.Ticket, entry.Description);
    }

    private Task HandleCheckInDelete(int id)
    {
        return Task.CompletedTask;
    }

    private async Task HandleEstimatedEndSelected(DateTime? estimatedEnd)
    {
        if (estimatedEnd.HasValue)
        {
            await AppState.SetSnooze(estimatedEnd.Value);
        }
    }

    private Task HandleCancelCheckIn()
    {
        AppState.HideCheckInPopup();
        return Task.CompletedTask;
    }

    private TimeEntry BuildCheckInEntry()
    {
        var now = DateTime.Now;
        var rounded = RoundToNearestFiveMinutes(now);

        return new TimeEntry
        {
            Date = now.ToString("yyyy-MM-dd"),
            StartTime = rounded.ToString("HH:mm"),
            Type = AppState.CurrentTask?.Type ?? TaskType.Ticket,
            Ticket = AppState.CurrentTask?.Ticket,
            Description = AppState.CurrentTask?.Description,
            DayTargetHhmm = AppState.Settings.DefaultTargetHours
        };
    }

    private static DateTime RoundToNearestFiveMinutes(DateTime dt)
    {
        var minute = dt.Minute;
        var roundedMinute = (int)Math.Round(minute / 5.0) * 5;
        var rounded = new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0).AddMinutes(roundedMinute);

        if (rounded.Day != dt.Day)
        {
            rounded = new DateTime(dt.Year, dt.Month, dt.Day, 23, 55, 0);
        }

        return rounded;
    }

    private string FormatDiagnostic(DateTime? receivedAt, string? tickTime)
    {
        if (!receivedAt.HasValue)
        {
            return "none";
        }

        return tickTime is null
            ? receivedAt.Value.ToString("HH:mm:ss")
            : $"{tickTime} at {receivedAt.Value:HH:mm:ss}";
    }

    private string FormatNotificationDiagnostic()
    {
        if (!AppState.LastNotificationAttemptAt.HasValue)
        {
            return "none";
        }

        return $"{AppState.LastNotificationStatus} at {AppState.LastNotificationAttemptAt.Value:HH:mm:ss}";
    }

    private string FormatNextCheckIn()
    {
        return AppState.NextCheckInTime.HasValue
            ? AppState.NextCheckInTime.Value.ToString("yyyy-MM-dd HH:mm")
            : "n/a";
    }
}
