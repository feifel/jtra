@inherits LayoutComponentBase
@implements IDisposable

<div class="page" @onclick="OnFirstInteraction">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="next-checkin">Next check-in: @AppState.NextCheckInTime</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (ShowCheckInPopup)
{
    <CheckInPopup OnConfirm="HandleCheckInConfirm" OnSnoozeCallback="HandleSnooze" OnCancel="HandleCancelCheckIn" />
}

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private NotificationService NotificationService { get; set; } = default!;

    private bool ShowCheckInPopup => AppState.ShowCheckInPopup;
    private bool _lastPopupState = false;
    private bool _notificationPermissionRequested = false;

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
    }

    private async Task OnFirstInteraction()
    {
        if (!_notificationPermissionRequested)
        {
            _notificationPermissionRequested = true;
            await NotificationService.RequestPermissionAsync();
        }
    }

    private void OnAppStateChanged()
    {
        if (AppState.ShowCheckInPopup && !_lastPopupState && AppState.IsTimerTriggeredPopup)
        {
            _ = ShowCheckInNotification();
        }
        _lastPopupState = AppState.ShowCheckInPopup;
        StateHasChanged();
    }

    private async Task ShowCheckInNotification()
    {
        await NotificationService.ShowNotificationAsync("JTRA Check-in", "Time to record your current task!");
    }

    private async Task HandleCheckInConfirm((TaskType type, string? ticket, string? description) args)
    {
        await AppState.ConfirmCheckIn(args.type, args.ticket, args.description);
    }

    private async Task HandleCheckInConfirm((string time, TaskType type, string? ticket, string? description) args)
    {
        await AppState.ConfirmCheckIn(args.time, args.type, args.ticket, args.description);
    }

    private Task HandleCancelCheckIn()
    {
        AppState.HideCheckInPopup();
        return Task.CompletedTask;
    }

    private async Task HandleSnooze(DateTime snoozeUntil)
    {
        await AppState.SetSnooze(snoozeUntil);
    }
}
