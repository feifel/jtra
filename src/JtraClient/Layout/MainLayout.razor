@inherits LayoutComponentBase
@implements IDisposable

<div class="page" @onclick="OnFirstInteraction">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="next-checkin">Next check-in: @AppState.NextCheckInTime</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (ShowCheckInPopup)
{
    <EditEntryDialog Entry="checkInEntry" OnSave="HandleCheckInSave" OnDelete="HandleCheckInDelete" OnClose="HandleCancelCheckIn" />
}

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private NotificationService NotificationService { get; set; } = default!;

    private bool ShowCheckInPopup => AppState.ShowCheckInPopup;
    private bool _lastPopupState = false;
    private bool _notificationPermissionRequested = false;
    private TimeEntry checkInEntry = new();

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
    }

    private async Task OnFirstInteraction()
    {
        if (!_notificationPermissionRequested)
        {
            _notificationPermissionRequested = true;
            await NotificationService.RequestPermissionAsync();
        }
    }

    private void OnAppStateChanged()
    {
        if (AppState.ShowCheckInPopup && !_lastPopupState)
        {
            checkInEntry = BuildCheckInEntry();
        }

        if (AppState.ShowCheckInPopup && !_lastPopupState && AppState.IsTimerTriggeredPopup)
        {
            _ = ShowCheckInNotification();
        }
        _lastPopupState = AppState.ShowCheckInPopup;
        StateHasChanged();
    }

    private async Task ShowCheckInNotification()
    {
        await NotificationService.ShowNotificationAsync("JTRA Check-in", "Time to record your current task!");
    }

    private async Task HandleCheckInSave(TimeEntry entry)
    {
        await AppState.ConfirmCheckIn(entry.StartTime, entry.Type, entry.Ticket, entry.Description);
    }

    private Task HandleCheckInDelete(int id)
    {
        return Task.CompletedTask;
    }

    private Task HandleCancelCheckIn()
    {
        AppState.HideCheckInPopup();
        return Task.CompletedTask;
    }

    private TimeEntry BuildCheckInEntry()
    {
        var now = DateTime.Now;
        var rounded = RoundToNearestQuarter(now);

        return new TimeEntry
        {
            Date = now.ToString("yyyy-MM-dd"),
            StartTime = rounded.ToString("HH:mm"),
            Type = AppState.CurrentTask?.Type ?? TaskType.Ticket,
            Ticket = AppState.CurrentTask?.Ticket,
            Description = AppState.CurrentTask?.Description,
            DayTargetHhmm = AppState.Settings.DefaultTargetHours
        };
    }

    private static DateTime RoundToNearestQuarter(DateTime dt)
    {
        var minute = dt.Minute;
        var roundedMinute = (int)Math.Round(minute / 15.0) * 15;
        var rounded = new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0).AddMinutes(roundedMinute);

        if (rounded.Day != dt.Day)
        {
            rounded = new DateTime(dt.Year, dt.Month, dt.Day, 23, 45, 0);
        }

        return rounded;
    }
}
