@using JtraClient.Services

<div class="popup-overlay" @onclick="Close">
    <div class="popup-content" @onclick:stopPropagation="true">
        <h3>Restore Backup</h3>

        <div class="alert alert-info">
            <strong>Backup found for:</strong> @Backup?.Email<br />
            <strong>Last modified:</strong> @GetLastModified()<br />
            <strong>Time entries:</strong> @(Backup?.TimeEntries?.Count ?? 0)
        </div>

        <div class="form-group">
            <label>Restore mode:</label>
            <div class="form-check">
                <input type="radio" id="merge" name="restoreMode" checked="@(!isReplace)" @onchange="@(() => isReplace = false)" class="form-check-input" />
                <label class="form-check-label" for="merge">
                    <strong>Merge</strong> - Add backup data to existing data
                </label>
            </div>
            <div class="form-check">
                <input type="radio" id="replace" name="restoreMode" checked="@isReplace" @onchange="@(() => isReplace = true)" class="form-check-input" />
                <label class="form-check-label" for="replace">
                    <strong>Replace</strong> - Delete all current data first
                </label>
            </div>
        </div>

        @if (isReplace)
        {
            <div class="alert alert-danger">
                <strong>Warning:</strong> Replace mode will delete ALL your current data before restoring!
            </div>
        }

        <div class="popup-actions">
            <button class="btn btn-primary" @onclick="Confirm">Restore</button>
            <button class="btn btn-secondary" @onclick="Close">Cancel</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public BackupPayload? Backup { get; set; }
    [Parameter] public EventCallback<bool> OnConfirm { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool isReplace;

    private string GetLastModified()
    {
        if (Backup == null || Backup.LastModified == default)
        {
            return "Unknown";
        }
        return Backup.LastModified.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync(isReplace);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}
