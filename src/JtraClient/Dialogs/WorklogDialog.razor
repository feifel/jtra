@inject AppState AppState
@inject IndexedDbService IndexedDb

<div class="popup-overlay" @onclick="Close">
    <div class="popup-content" @onclick:stopPropagation="true">
        <h3>Edit Entry</h3>
        
        <div class="form-group">
            <label>Date</label>
            <input type="date" value="@entryDate" @onchange="HandleDateChanged" class="form-control" @onkeydown="HandleKeyDown" />
        </div>

        <div class="form-group">
            <label>Start Time</label>
            <select value="@entryStartTime" @onchange="HandleStartTimeChanged" class="form-control" @onkeydown="HandleKeyDown">
                @foreach (var t in timeOptions)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>

        @if (ShowEstimatedEndOption)
        {
            <div class="form-group">
                <label>Estimated End</label>
                <select @bind="selectedEstimatedEndTime" class="form-control" @onkeydown="HandleKeyDown">
                    @foreach (var t in timeOptions)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
        }

        <div class="form-group">
            <label>Task Type</label>
            <select value="@selectedTaskSelection" @onchange="HandleTaskSelectionChanged" class="form-control" @onkeydown="HandleKeyDown">
                <option value="@BreakSelectionValue">Break</option>
                @foreach (var task in AppState.AllTaskEntries.OrderBy(e => e.Category).ThenBy(e => e.Subcategory))
                {
                    <option value="@task.Id">@FormatTaskOption(task)</option>
                }
                <option value="@CustomSelectionValue">Custom</option>
            </select>
        </div>

        @if (Entry.Type != TaskType.Break)
        {
            <div class="form-group">
                <label>Ticket</label>
                <div class="input-with-button">
                    <input type="text" @bind="Entry.Ticket" @bind:event="oninput" class="form-control" placeholder="JIRA-123" @onkeydown="HandleKeyDown" />
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ShowTicketPicker">...</button>
                </div>
            </div>
        }

        <div class="form-group">
            <label>Description</label>
            <input type="text" @bind="Entry.Description" @bind:event="oninput" class="form-control" maxlength="100" @onkeydown="HandleKeyDown" />
        </div>

        <div class="popup-actions">
            <button class="btn btn-primary" @onclick="Save">Save</button>
            @if (Entry.Id > 0)
            {
                <button class="btn btn-danger" @onclick="Delete">Delete</button>
            }
            <button class="btn btn-secondary" @onclick="Close">Cancel</button>
        </div>

        @if (showTicketPicker)
        {
            <div class="ticket-picker">
                <div class="ticket-picker-header">
                    <span>Select Ticket</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="HideTicketPicker">X</button>
                </div>
                @if (favoriteTickets.Any())
                {
                    <div class="ticket-picker-list">
                        @foreach (var fav in favoriteTickets.OrderByDescending(t => t.LastUsedAt))
                        {
                            <div class="ticket-picker-item" @onclick="() => SelectTicket(fav.TicketKey)">
                                <span class="ticket-key">@fav.TicketKey</span>
                                @if (!string.IsNullOrEmpty(fav.Summary))
                                {
                                    <span class="ticket-summary">@fav.Summary</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ticket-picker-empty">No tickets yet</div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public TimeEntry Entry { get; set; } = new();
    [Parameter] public EventCallback<TimeEntry> OnSave { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<DateTime?> OnEstimatedEndSelected { get; set; }
    [Parameter] public bool ShowEstimatedEndOption { get; set; }

    private string entryDate = DateTime.Today.ToString("yyyy-MM-dd");
    private string entryStartTime = "09:00";
    private List<string> timeOptions = new();
    private bool showTicketPicker;
    private List<TicketCache> favoriteTickets = new();
    private string selectedTaskSelection = CustomSelectionValue;
    private string selectedEstimatedEndTime = "09:00";
    private int? lastEntryId;
    private bool lastShowEstimatedEndOption;

    private const string BreakSelectionValue = "__break__";
    private const string CustomSelectionValue = "__custom__";

    protected override void OnInitialized()
    {
        timeOptions = GenerateAllTimeOptions();
    }

    protected override void OnParametersSet()
    {
        entryDate = Entry.Date;
        entryStartTime = NormalizeTime(Entry.StartTime);
        selectedTaskSelection = GetTaskSelectionForEntry();

        if (lastEntryId != Entry.Id || lastShowEstimatedEndOption != ShowEstimatedEndOption)
        {
            selectedEstimatedEndTime = GetDefaultEstimatedEndTime();
            lastEntryId = Entry.Id;
            lastShowEstimatedEndOption = ShowEstimatedEndOption;

            // If editing today's latest entry and we have a previously selected estimated end, restore it
            if (ShowEstimatedEndOption && Entry.Date == DateTime.Today.ToString("yyyy-MM-dd") && 
                AppState.LastSelectedEstimatedEnd.HasValue && 
                AppState.LastSelectedEstimatedEnd.Value.Date == DateTime.Today)
            {
                selectedEstimatedEndTime = $"{AppState.LastSelectedEstimatedEnd.Value.Hour:D2}:{AppState.LastSelectedEstimatedEnd.Value.Minute:D2}";
            }
        }
    }

    private string GetDefaultEstimatedEndTime()
    {
        var interval = Math.Clamp(AppState.Settings.NotificationIntervalMinutes, 1, 60);
        if (!TimeSpan.TryParse(entryStartTime, out var start))
        {
            start = DateTime.Now.TimeOfDay;
        }

        var baseDate = GetSelectedEntryDate();
        var estimated = baseDate.Add(start).AddMinutes(interval);
        var roundedMinute = ((estimated.Minute + 4) / 5) * 5;
        if (roundedMinute == 60)
        {
            estimated = new DateTime(estimated.Year, estimated.Month, estimated.Day, estimated.Hour, 0, 0).AddHours(1);
        }
        else
        {
            estimated = new DateTime(estimated.Year, estimated.Month, estimated.Day, estimated.Hour, roundedMinute, 0);
        }

        if (baseDate.Date == DateTime.Today && estimated <= DateTime.Now)
        {
            estimated = estimated.AddDays(1);
        }

        return $"{estimated.Hour:D2}:{estimated.Minute:D2}";
    }

    private void HandleDateChanged(ChangeEventArgs e)
    {
        entryDate = e.Value?.ToString() ?? entryDate;

        if (ShowEstimatedEndOption)
        {
            selectedEstimatedEndTime = GetDefaultEstimatedEndTime();
        }
    }

    private void HandleStartTimeChanged(ChangeEventArgs e)
    {
        entryStartTime = NormalizeTime(e.Value?.ToString() ?? entryStartTime);

        if (ShowEstimatedEndOption)
        {
            selectedEstimatedEndTime = GetDefaultEstimatedEndTime();
        }
    }

    private void HandleTaskSelectionChanged(ChangeEventArgs e)
    {
        selectedTaskSelection = e.Value?.ToString() ?? CustomSelectionValue;

        if (selectedTaskSelection == BreakSelectionValue)
        {
            Entry.Type = TaskType.Break;
            Entry.Ticket = null;
            return;
        }

        if (int.TryParse(selectedTaskSelection, out var taskId))
        {
            var task = AppState.AllTaskEntries.FirstOrDefault(t => t.Id == taskId);
            if (task != null)
            {
                Entry.Type = TaskType.Ticket;
                Entry.Ticket = task.Ticket;
                Entry.Description = task.Description;
            }
            return;
        }

        if (Entry.Type == TaskType.Break)
        {
            Entry.Type = TaskType.Ticket;
        }
    }

    private async Task ShowTicketPicker()
    {
        favoriteTickets = await IndexedDb.GetAllCachedTicketsAsync();
        showTicketPicker = true;
    }

    private void HideTicketPicker()
    {
        showTicketPicker = false;
    }

    private void SelectTicket(string ticketKey)
    {
        Entry.Ticket = ticketKey;
        showTicketPicker = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Save();
        }
    }

    private async Task Save()
    {
        Entry.Date = entryDate;
        Entry.StartTime = NormalizeTime(entryStartTime);
        await OnSave.InvokeAsync(Entry);

        if (ShowEstimatedEndOption)
        {
            await OnEstimatedEndSelected.InvokeAsync(ParseEstimatedEndDateTime());
        }
    }

    private DateTime? ParseEstimatedEndDateTime()
    {
        if (!TimeSpan.TryParse(selectedEstimatedEndTime, out var selectedTime))
        {
            return null;
        }

        var baseDate = GetSelectedEntryDate();
        var estimatedEnd = baseDate.Add(selectedTime);
        if (baseDate.Date == DateTime.Today && estimatedEnd <= DateTime.Now)
        {
            estimatedEnd = estimatedEnd.AddDays(1);
        }

        return estimatedEnd >= DateTime.Now ? estimatedEnd : (DateTime?)null;
    }

    private DateTime GetSelectedEntryDate()
    {
        if (!string.IsNullOrWhiteSpace(entryDate))
        {
            var parts = entryDate.Split('-');
            if (parts.Length == 3 &&
                int.TryParse(parts[0], out var year) &&
                int.TryParse(parts[1], out var month) &&
                int.TryParse(parts[2], out var day))
            {
                try
                {
                    return new DateTime(year, month, day);
                }
                catch
                {
                    // Fall back to today for invalid date fragments.
                }
            }
        }

        return DateTime.Today;
    }

    private static string NormalizeTime(string time)
    {
        if (string.IsNullOrEmpty(time)) return time;
        var parts = time.Split(':');
        if (parts.Length >= 2)
            return $"{parts[0]}:{parts[1]}";
        return time;
    }

    private string GetTaskSelectionForEntry()
    {
        if (Entry.Type == TaskType.Break)
        {
            return BreakSelectionValue;
        }

        var match = AppState.AllTaskEntries.FirstOrDefault(task =>
            string.Equals(task.Ticket ?? string.Empty, Entry.Ticket ?? string.Empty, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(task.Description ?? string.Empty, Entry.Description ?? string.Empty, StringComparison.Ordinal));

        return match?.Id.ToString() ?? CustomSelectionValue;
    }

    private static string FormatTaskOption(TaskEntry task)
    {
        var category = task.Category;
        var subcategory = string.IsNullOrWhiteSpace(task.Subcategory) ? string.Empty : $" / {task.Subcategory}";
        var ticket = string.IsNullOrWhiteSpace(task.Ticket) ? string.Empty : $" ({task.Ticket})";
        return $"{category}{subcategory}{ticket}";
    }

    private async Task Delete()
    {
        await OnDelete.InvokeAsync(Entry.Id);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private static List<string> GenerateAllTimeOptions()
    {
        var options = new List<string>();
        for (int h = 0; h < 24; h++)
        {
            for (int m = 0; m < 60; m += 5)
            {
                options.Add($"{h:D2}:{m:D2}");
            }
        }
        return options;
    }
}
