@page "/settings"
@implements IDisposable

<PageTitle>JTRA - Settings</PageTitle>

<h2>Settings</h2>

<div class="settings-form">
    <div class="form-group">
        <label>JIRA Base URL</label>
        <input type="url" @bind="settings.JiraBaseUrl" class="form-control" placeholder="https://your-company.atlassian.net" />
    </div>

    <div class="form-group">
        <label>Personal Access Token (PAT)</label>
        <input type="password" @bind="settings.Pat" class="form-control" placeholder="Your JIRA PAT" />
        <small class="form-text text-muted">Stored locally in your browser only.</small>
    </div>

    <div class="form-group">
        <label>Default Target Hours</label>
        <input type="time" value="@defaultTargetHours" @onchange="@((ChangeEventArgs e) => defaultTargetHours = e.Value?.ToString() ?? "08:00")" class="form-control" />
    </div>

    <div class="form-group">
        <label>Max Snooze Hours</label>
        <input type="number" @bind="settings.MaxSnoozeHours" class="form-control" min="1" max="8" />
    </div>

    <div class="form-group">
        <label>Auto-confirm Break Minutes</label>
        <input type="number" @bind="settings.AutoConfirmBreakMinutes" class="form-control" min="1" max="30" />
    </div>

    <div class="form-group">
        <label>Ticket Cache Size</label>
        <input type="number" @bind="settings.TicketCacheSize" class="form-control" min="5" max="100" />
        <small class="form-text text-muted">Maximum number of recently used tickets to cache.</small>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" @bind="settings.Use24HourFormat" class="form-check-input" id="use24h" />
        <label class="form-check-label" for="use24h">Use 24-hour time format</label>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" @bind="settings.CsvExportOldestFirst" class="form-check-input" id="csvOldestFirst" />
        <label class="form-check-label" for="csvOldestFirst">CSV export: oldest entries first</label>
    </div>

    <div class="actions">
        <button class="btn btn-primary" @onclick="SaveSettings">Save Settings</button>
        <button class="btn btn-secondary" @onclick="ResetToDefaults">Reset to Defaults</button>
    </div>
</div>

<div class="data-section">
    <h3>Data Management</h3>
    <div class="actions">
        <button class="btn btn-success" @onclick="ExportData">Export CSV</button>
        <label class="btn btn-warning mb-0">
            Import CSV
            <input type="file" @ref="fileInput" @onchange="ImportData" accept=".csv" style="display: none;" />
        </label>
        <button class="btn btn-danger" @onclick="ClearAllData">Clear All Data</button>
    </div>
</div>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IndexedDbService IndexedDb { get; set; } = default!;
    [Inject] private CsvExportService CsvExport { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private AppSettings settings = new();
    private string defaultTargetHours = "08:00";
    private ElementReference fileInput;

    protected override void OnInitialized()
    {
        settings = new AppSettings
        {
            JiraBaseUrl = AppState.Settings.JiraBaseUrl,
            Pat = AppState.Settings.Pat,
            DefaultTargetHours = AppState.Settings.DefaultTargetHours,
            MaxSnoozeHours = AppState.Settings.MaxSnoozeHours,
            AutoConfirmBreakMinutes = AppState.Settings.AutoConfirmBreakMinutes,
            TicketCacheSize = AppState.Settings.TicketCacheSize,
            Use24HourFormat = AppState.Settings.Use24HourFormat,
            CsvExportOldestFirst = AppState.Settings.CsvExportOldestFirst
        };
        
        defaultTargetHours = settings.DefaultTargetHours;

        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private async Task SaveSettings()
    {
        settings.DefaultTargetHours = defaultTargetHours;
        await AppState.SaveSettingsAsync(settings);
    }

    private void ResetToDefaults()
    {
        settings = new AppSettings();
        defaultTargetHours = "08:00";
    }

    private async Task ExportData()
    {
        var csv = CsvExport.ExportToCsv(AppState.AllEntries, settings.CsvExportOldestFirst);
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        
        await JS.InvokeVoidAsync("downloadFile", $"jtra-export-{DateTime.Today:yyyy-MM-dd}.csv", "text/csv", base64);
    }

    private async Task ImportData(ChangeEventArgs e)
    {
        var fileContent = await JS.InvokeAsync<string>("readFileContentFromInput", fileInput);
        if (string.IsNullOrEmpty(fileContent)) return;
        
        var entries = CsvExport.ImportFromCsv(fileContent);
        foreach (var entry in entries)
        {
            await AppState.AddNewEntryAsync(entry);
        }
    }

    private async Task ClearAllData()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to clear all data? This cannot be undone.");
        if (confirmed)
        {
            await IndexedDb.ClearAllDataAsync();
            await AppState.RefreshEntriesAsync();
        }
    }
}
