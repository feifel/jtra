@page "/settings"
@implements IDisposable

<PageTitle>JTRA - Settings</PageTitle>

<h2>Settings</h2>

@if (showPatDialog)
{
    <PatDialog OnSave="@OnPatDialogSave" OnClose="@(() => showPatDialog = false)" />
}

<div class="settings-form">
    <div class="form-group">
        <label>Email</label>
        <input type="email" readonly value="@settings.Email" class="form-control" placeholder="Not configured" />
        <small class="form-text text-muted">Retrieved from JIRA when you configure your PAT.</small>
    </div>

    <div class="form-group">
        <label>JIRA Base URL</label>
        <input type="url" @bind="settings.JiraBaseUrl" class="form-control" placeholder="https://your-company.atlassian.net" />
    </div>

    <div class="form-group">
        <label>Personal Access Token (PAT)</label>
        <div class="input-group">
            <input type="password" readonly value="@GetMaskedPat()" class="form-control" placeholder="Not configured" />
            <button class="btn btn-outline-secondary" type="button" @onclick="@(() => showPatDialog = true)">Configure</button>
        </div>
        <small class="form-text text-muted">Stored locally in your browser only.</small>
    </div>

    <div class="form-group">
        <label>Default Target Hours</label>
        <input type="time" value="@defaultTargetHours" @onchange="@((ChangeEventArgs e) => defaultTargetHours = e.Value?.ToString() ?? "08:00")" class="form-control" />
    </div>

    <div class="form-group">
        <label>Check-in Interval</label>
        <select @bind="settings.NotificationIntervalMinutes" class="form-control">
            @foreach (var interval in GetNotificationIntervalOptions())
            {
                <option value="@interval">Every @interval minute@(interval == 1 ? string.Empty : "s")</option>
            }
        </select>
        <small class="form-text text-muted">The server sends a heartbeat every minute. Your browser decides when to show the check-in popup.</small>
    </div>

    <div class="form-group">
        <label>Auto-confirm Break Minutes</label>
        <input type="number" @bind="settings.AutoConfirmBreakMinutes" class="form-control" min="1" max="30" />
    </div>

    <div class="form-group form-check">
        <input type="checkbox" @bind="settings.Use24HourFormat" class="form-check-input" id="use24h" />
        <label class="form-check-label" for="use24h">Use 24-hour time format</label>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" @bind="settings.CsvExportOldestFirst" class="form-check-input" id="csvOldestFirst" />
        <label class="form-check-label" for="csvOldestFirst">CSV export: oldest entries first</label>
    </div>

    <div class="actions">
        <button class="btn btn-primary" @onclick="SaveSettings">Save Settings</button>
        <button class="btn btn-secondary" @onclick="ResetToDefaults">Reset to Defaults</button>
    </div>
</div>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private AppSettings settings = new();
    private string defaultTargetHours = "08:00";
    private bool showPatDialog;

    protected override void OnInitialized()
    {
        settings = new AppSettings
        {
            JiraBaseUrl = AppState.Settings.JiraBaseUrl,
            Pat = AppState.Settings.Pat,
            Email = AppState.Settings.Email,
            DefaultTargetHours = AppState.Settings.DefaultTargetHours,
            NotificationIntervalMinutes = AppState.Settings.NotificationIntervalMinutes,
            AutoConfirmBreakMinutes = AppState.Settings.AutoConfirmBreakMinutes,
            Use24HourFormat = AppState.Settings.Use24HourFormat,
            CsvExportOldestFirst = AppState.Settings.CsvExportOldestFirst
        };
        
        defaultTargetHours = settings.DefaultTargetHours;

        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private string GetMaskedPat()
    {
        if (string.IsNullOrEmpty(settings.Pat)) return string.Empty;
        if (settings.Pat.Length <= 4) return "****";
        return settings.Pat[..4] + new string('*', Math.Min(settings.Pat.Length - 4, 20));
    }

    private async Task OnPatDialogSave((string Pat, string Email) result)
    {
        settings.Pat = result.Pat;
        settings.Email = result.Email;
        showPatDialog = false;
        await AppState.SaveSettingsAsync(settings);
    }

    private async Task SaveSettings()
    {
        settings.DefaultTargetHours = defaultTargetHours;
        await AppState.SaveSettingsAsync(settings);
    }

    private void ResetToDefaults()
    {
        settings = new AppSettings();
        defaultTargetHours = "08:00";
    }

    private IEnumerable<int> GetNotificationIntervalOptions()
    {
        yield return 1;
        yield return 5;
        yield return 10;
        yield return 15;
        yield return 20;
        yield return 30;
        yield return 60;
    }
}
