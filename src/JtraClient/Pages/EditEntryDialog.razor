@inject AppState AppState
@inject IndexedDbService IndexedDb

<div class="popup-overlay" @onclick="Close">
    <div class="popup-content" @onclick:stopPropagation="true">
        <h3>Edit Entry</h3>
        
        <div class="form-group">
            <label>Date</label>
            <input type="date" value="@entryDate" @onchange="@((ChangeEventArgs e) => entryDate = e.Value?.ToString() ?? "")" class="form-control" @onkeydown="HandleKeyDown" />
        </div>

        <div class="form-group">
            <label>Start Time</label>
            <select @bind="entryStartTime" class="form-control" @onkeydown="HandleKeyDown">
                @foreach (var t in timeOptions)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Task Type</label>
            <select @bind="Entry.Type" class="form-control" @onkeydown="HandleKeyDown">
                @foreach (TaskType type in Enum.GetValues(typeof(TaskType)))
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>

        @if (Entry.Type == TaskType.Ticket)
        {
            <div class="form-group">
                <label>Ticket</label>
                <div class="input-with-button">
                    <input type="text" @bind="Entry.Ticket" @bind:event="oninput" class="form-control" placeholder="JIRA-123" @onkeydown="HandleKeyDown" />
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ShowTicketPicker">...</button>
                </div>
            </div>
        }

        <div class="form-group">
            <label>Description</label>
            <input type="text" @bind="Entry.Description" @bind:event="oninput" class="form-control" maxlength="100" @onkeydown="HandleKeyDown" />
        </div>

        <div class="form-group">
            <label>Target Hours</label>
            <select @bind="entryTargetHours" class="form-control" @onkeydown="HandleKeyDown">
                @foreach (var t in targetHourOptions)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>

        <div class="popup-actions">
            <button class="btn btn-primary" @onclick="Save">Save</button>
            @if (Entry.Id > 0)
            {
                <button class="btn btn-danger" @onclick="Delete">Delete</button>
            }
            <button class="btn btn-secondary" @onclick="Close">Cancel</button>
        </div>

        @if (showTicketPicker)
        {
            <div class="ticket-picker">
                <div class="ticket-picker-header">
                    <span>Select from Favorites</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="HideTicketPicker">X</button>
                </div>
                @if (favoriteTickets.Any())
                {
                    <div class="ticket-picker-list">
                        @foreach (var fav in favoriteTickets.OrderByDescending(t => t.LastUsedAt))
                        {
                            <div class="ticket-picker-item" @onclick="() => SelectTicket(fav.TicketKey)">
                                <span class="ticket-key">@fav.TicketKey</span>
                                @if (!string.IsNullOrEmpty(fav.Summary))
                                {
                                    <span class="ticket-summary">@fav.Summary</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ticket-picker-empty">No favorite tickets yet</div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public TimeEntry Entry { get; set; } = new();
    [Parameter] public EventCallback<TimeEntry> OnSave { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string entryDate = DateTime.Today.ToString("yyyy-MM-dd");
    private string entryStartTime = "09:00";
    private string entryTargetHours = "08:00";
    private List<string> timeOptions = new();
    private List<string> targetHourOptions = new();
    private bool showTicketPicker;
    private List<TicketCache> favoriteTickets = new();

    protected override void OnInitialized()
    {
        timeOptions = GenerateAllTimeOptions();
        targetHourOptions = GenerateTargetHourOptions();
    }

    protected override void OnParametersSet()
    {
        entryDate = Entry.Date;
        entryStartTime = NormalizeTime(Entry.StartTime);
        entryTargetHours = NormalizeTime(Entry.DayTargetHhmm);
    }

    private async Task ShowTicketPicker()
    {
        favoriteTickets = await IndexedDb.GetAllCachedTicketsAsync();
        showTicketPicker = true;
    }

    private void HideTicketPicker()
    {
        showTicketPicker = false;
    }

    private void SelectTicket(string ticketKey)
    {
        Entry.Ticket = ticketKey;
        showTicketPicker = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Save();
        }
    }

    private async Task Save()
    {
        Entry.Date = entryDate;
        Entry.StartTime = NormalizeTime(entryStartTime);
        Entry.DayTargetHhmm = NormalizeTime(entryTargetHours);
        await OnSave.InvokeAsync(Entry);
    }

    private static string NormalizeTime(string time)
    {
        if (string.IsNullOrEmpty(time)) return time;
        var parts = time.Split(':');
        if (parts.Length >= 2)
            return $"{parts[0]}:{parts[1]}";
        return time;
    }

    private async Task Delete()
    {
        await OnDelete.InvokeAsync(Entry.Id);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private static List<string> GenerateAllTimeOptions()
    {
        var options = new List<string>();
        for (int h = 0; h < 24; h++)
        {
            options.Add($"{h:D2}:00");
            options.Add($"{h:D2}:15");
            options.Add($"{h:D2}:30");
            options.Add($"{h:D2}:45");
        }
        return options;
    }

    private static List<string> GenerateTargetHourOptions()
    {
        var options = new List<string>();
        for (int h = 0; h <= 12; h++)
        {
            options.Add($"{h:D2}:00");
            options.Add($"{h:D2}:30");
        }
        return options;
    }
}
