@page "/tasks"
@implements IDisposable

<PageTitle>JTRA - Tasks</PageTitle>

<div class="entries-header">
    <h2>Tasks</h2>
    <div class="header-buttons">
        <button class="btn btn-primary" @onclick="ShowNewEntryDialog">Add</button>
        <div class="dropdown" style="position: relative; display: inline-block;">
            <button class="btn btn-outline-secondary" @onclick="ToggleDataMenu" @onclick:stopPropagation="true">...</button>
            @if (showDataMenu)
            {
                <div class="dropdown-menu show" style="display: block; position: absolute; right: 0; top: 100%; z-index: 1000;">
                    <button class="dropdown-item" @onclick="ExportData" @onclick:stopPropagation="true">Export CSV</button>
                    <label class="dropdown-item mb-0" style="cursor: pointer;">
                        Import CSV
                        <input type="file" @ref="fileInput" @onchange="ImportData" accept=".csv" style="display: none;" />
                    </label>
                </div>
            }
        </div>
    </div>
</div>

<div class="entries-list tasks-list">
    <div class="entry-row entry-header">
        <div class="entry-category">Category</div>
        <div class="entry-subcategory">Subcategory</div>
        <div class="entry-ticket">Ticket</div>
        <div class="entry-description">Description</div>
    </div>
    @foreach (var entry in AppState.AllTaskEntries.OrderBy(e => e.Category).ThenBy(e => e.Subcategory))
    {
        <div class="entry-row" @ondblclick="() => StartEdit(entry)">
            <div class="entry-category">@entry.Category</div>
            <div class="entry-subcategory">@entry.Subcategory</div>
            <div class="entry-ticket">@entry.Ticket</div>
            <div class="entry-description">@entry.Description</div>
        </div>
    }
    @if (!AppState.AllTaskEntries.Any())
    {
        <p class="no-entries" style="padding: 0.5rem 1rem;">No task types configured.</p>
    }
</div>

@if (showEditDialog && editingEntry != null)
{
    <TaskDialog Entry="editingEntry" OnSave="SaveEntry" OnDelete="DeleteEntry" OnClose="CloseEditDialog" />
}

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private CsvExportService CsvExport { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool showEditDialog = false;
    private bool showDataMenu = false;
    private TaskEntry? editingEntry;
    private ElementReference fileInput;

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void ShowNewEntryDialog()
    {
        editingEntry = new TaskEntry();
        showEditDialog = true;
    }

    private void StartEdit(TaskEntry entry)
    {
        editingEntry = new TaskEntry
        {
            Id = entry.Id,
            Category = entry.Category,
            Subcategory = entry.Subcategory,
            Ticket = entry.Ticket,
            Description = entry.Description
        };
        showEditDialog = true;
    }

    private async Task SaveEntry(TaskEntry entry)
    {
        if (entry.Id > 0)
        {
            await AppState.UpdateTaskEntryAsync(entry);
        }
        else
        {
            await AppState.AddNewTaskEntryAsync(entry);
        }
    }

    private async Task DeleteEntry(int id)
    {
        await AppState.DeleteTaskEntryAsync(id);
        showEditDialog = false;
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
    }

    private void ToggleDataMenu()
    {
        showDataMenu = !showDataMenu;
    }

    private async Task ExportData()
    {
        showDataMenu = false;
        var csv = CsvExport.ExportTasksToCsv(AppState.AllTaskEntries);
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"jtra-tasks-export-{DateTime.Today:yyyy-MM-dd}.csv", "text/csv", base64);
    }

    private async Task ImportData(ChangeEventArgs e)
    {
        showDataMenu = false;
        var fileContent = await JS.InvokeAsync<string>("readFileContentFromInput", fileInput);
        if (string.IsNullOrEmpty(fileContent)) return;
        var entries = CsvExport.ImportTasksFromCsv(fileContent);
        foreach (var entry in entries)
        {
            await AppState.AddNewTaskEntryAsync(entry);
        }
    }
}
