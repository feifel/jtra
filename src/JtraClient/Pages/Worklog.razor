@page "/"
@page "/worklog"
@implements IDisposable

<PageTitle>JTRA - Worklog</PageTitle>

<div class="home-layout">
    <div class="today-stats">
        <div class="stat-card">
            <h3>Target</h3>
            <span class="stat-value">@AppState.TodayTarget.ToString(@"hh\:mm")</span>
        </div>
        <div class="stat-card">
            <h3>Logged</h3>
            <span class="stat-value">@AppState.TodayAccumulated.ToString(@"hh\:mm")</span>
        </div>
        <div class="stat-card @(AppState.TodayDeviation.TotalMinutes < 0 ? "negative" : "positive")">
            <h3>Deviation</h3>
            <span class="stat-value">@AppState.TodayDeviation.ToString(@"hh\:mm")</span>
        </div>
    </div>

    <div class="entries-scroll-container" @ref="scrollContainer">
        <div class="entries-list">
            <div class="entry-row entry-header">
                <div class="entry-datetime">Date &amp; Time</div>
                <div class="entry-category">Category</div>
                <div class="entry-subcategory">Subcategory</div>
                <div class="entry-ticket">Ticket</div>
                <div class="entry-description">Description</div>
                <div class="entry-duration">Duration</div>
                <div class="entry-actions" style="text-align: center;">Pending</div>
            </div>
            @if (!AppState.AllEntries.Any())
            {
                <p class="no-entries">No entries yet.</p>
            }
            @foreach (var entry in AppState.AllEntries.OrderBy(e => e.Date).ThenBy(e => DurationCalculator.GetStartMinutesOrMax(e.StartTime)).ThenBy(e => e.StartTime).ThenBy(e => e.Id))
            {
                var (entryCategory, entrySubcategory) = GetEntryLabels(entry);
                var calculatedDuration = DurationCalculator.FormatMinutes(DurationCalculator.CalculateDurationMinutes(AppState.AllEntries, entry));
                <div class="entry-row" @ondblclick="() => StartEdit(entry)">
                    <div class="entry-datetime">@FormatDateTime(entry.Date, entry.StartTime)</div>
                    <div class="entry-category">@entryCategory</div>
                    <div class="entry-subcategory">@entrySubcategory</div>
                    <div class="entry-ticket">@entry.Ticket</div>
                    <div class="entry-description">@entry.Description</div>
                    <div class="entry-duration">@calculatedDuration</div>
                    <div class="entry-actions" style="display: flex; justify-content: center; align-items: center;">
                        @if (IsJiraSubmittable(entry))
                        {
                            <input type="checkbox" @bind="entry.PendingForJiraSubmission" @bind:event="oninput" @onclick:stopPropagation="true" @onchange="() => SavePending(entry)" title="Checked means this entry will be included in the next bulk JIRA submission." />
                        }
                        else
                        {
                            <span title="This entry has no ticket and cannot be submitted to JIRA">-</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="entry-row inline-add-row">
        <div class="entry-datetime inline-datetime-cell">
            <input type="text" value="@inlineDateTimeText" @onchange="HandleInlineDateTimeChanged" class="form-control form-control-sm inline-datetime-input" placeholder="yyyy.MM.dd HH:mm" />
            <div class="spin-buttons" title="Step by Check-In Interval">
                <button type="button" class="btn btn-sm btn-outline-secondary spin-btn" @onclick="IncrementTime">&#9650;</button>
                <button type="button" class="btn btn-sm btn-outline-secondary spin-btn" @onclick="DecrementTime">&#9660;</button>
            </div>
        </div>
        <div class="entry-category inline-add-category">
            <select value="@inlineTaskSelection" @onchange="HandleInlineTaskChanged" class="form-control form-control-sm">
                <option value="@BreakSelectionValue">Break</option>
                @foreach (var task in AppState.AllTaskEntries.OrderBy(t => t.Category).ThenBy(t => t.Subcategory))
                {
                    <option value="@task.Id">@FormatTaskOption(task)</option>
                }
            </select>
        </div>
        <div class="entry-ticket">
            @if (inlineTaskSelection != BreakSelectionValue)
            {
                <input type="text" @bind="inlineTicket" class="form-control form-control-sm" placeholder="JIRA-123" />
            }
        </div>
        <div class="entry-description">
            <input type="text" @bind="inlineDescription" @bind:event="oninput" class="form-control form-control-sm" placeholder="Description..." maxlength="100" @onkeydown="HandleInlineKeyDown" />
        </div>
        <div class="entry-duration"></div>
        <div class="entry-actions" style="display: flex; justify-content: center; align-items: center;">
            <button class="btn btn-sm btn-primary" @onclick="AddInlineEntry">Add</button>
            <div class="dropdown" style="position: relative; display: inline-block; margin-left: 0.25rem;">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleDataMenu" @onclick:stopPropagation="true">...</button>
                @if (showDataMenu)
                {
                    <div class="dropdown-menu show" style="display: block; position: absolute; right: 0; bottom: 100%; z-index: 1000;">
                        <button class="dropdown-item" @onclick="SubmitPendingTasks" @onclick:stopPropagation="true" disabled="@submitting">
                            @if (submitting)
                            {
                                <span>Submitting...</span>
                            }
                            else
                            {
                                <span>Submit pending tasks</span>
                            }
                        </button>
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item" @onclick="ExportData" @onclick:stopPropagation="true">Export CSV</button>
                        <label class="dropdown-item mb-0" style="cursor: pointer;">
                            Import CSV
                            <input type="file" @ref="fileInput" @onchange="ImportData" accept=".csv" style="display: none;" />
                        </label>
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item text-danger" @onclick="ClearAllData" @onclick:stopPropagation="true">Clear All Data</button>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (showEditDialog && editingEntry != null)
    {
        <WorklogDialog Entry="editingEntry"
                         OnSave="SaveEntry"
                         OnDelete="DeleteEntry"
                         OnClose="CloseEditDialog"
                         OnEstimatedEndSelected="HandleEstimatedEndSelected"
                         ShowEstimatedEndOption="showEstimatedEndForEditingEntry" />
    }
</div>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IndexedDbService IndexedDb { get; set; } = default!;
    [Inject] private CsvExportService CsvExport { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private ILogger<Worklog> Logger { get; set; } = default!;

    private bool showEditDialog = false;
    private bool showDataMenu = false;
    private bool submitting = false;
    private TimeEntry? editingEntry;
    private bool showEstimatedEndForEditingEntry;
    private ElementReference fileInput;
    private ElementReference scrollContainer;
    private bool _shouldScroll = true;

    private string inlineDateTimeText = string.Empty;
    private string inlineTaskSelection = BreakSelectionValue;
    private string inlineTicket = string.Empty;
    private string inlineDescription = string.Empty;
    private TaskType inlineTaskType = TaskType.Ticket;

    private const string BreakSelectionValue = "__break__";

    protected override void OnInitialized()
    {
        inlineDateTimeText = FormatInlineDateTime(RoundToNearest5(DateTime.Now));
        InitializeInlineTaskSelection();
        AppState.OnChange += OnAppStateChanged;
    }

    private void InitializeInlineTaskSelection()
    {
        var firstTask = AppState.AllTaskEntries
            .OrderBy(t => t.Category)
            .ThenBy(t => t.Subcategory)
            .FirstOrDefault();

        if (firstTask != null)
        {
            ApplyInlineTaskSelection(firstTask.Id.ToString());
        }
        else
        {
            ApplyInlineTaskSelection(BreakSelectionValue);
        }
    }

    private void OnAppStateChanged()
    {
        _shouldScroll = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _shouldScroll)
        {
            _shouldScroll = false;
            try
            {
                await JS.InvokeVoidAsync("scrollToBottom", scrollContainer);
            }
            catch
            {
                // Element may not be ready; ignore
            }
        }
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
    }

    private void HandleInlineDateTimeChanged(ChangeEventArgs e)
    {
        inlineDateTimeText = e.Value?.ToString() ?? inlineDateTimeText;
    }

    private void HandleInlineTaskChanged(ChangeEventArgs e)
    {
        ApplyInlineTaskSelection(e.Value?.ToString() ?? inlineTaskSelection);
    }

    private void ApplyInlineTaskSelection(string selection)
    {
        inlineTaskSelection = selection;

        if (inlineTaskSelection == BreakSelectionValue)
        {
            inlineTaskType = TaskType.Break;
            inlineTicket = string.Empty;
            inlineDescription = string.Empty;
            return;
        }

        if (int.TryParse(inlineTaskSelection, out var taskId))
        {
            var task = AppState.AllTaskEntries.FirstOrDefault(t => t.Id == taskId);
            if (task != null)
            {
                inlineTaskType = TaskType.Ticket;
                inlineTicket = task.Ticket ?? string.Empty;
                inlineDescription = task.Description ?? string.Empty;
                return;
            }
        }

        InitializeInlineTaskSelection();
    }

    private void IncrementTime()
    {
        AdjustInlineTime(AppState.Settings.NotificationIntervalMinutes);
    }

    private void DecrementTime()
    {
        AdjustInlineTime(-AppState.Settings.NotificationIntervalMinutes);
    }

    private void AdjustInlineTime(int minutes)
    {
        var dt = ParseInlineDateTimeLocal();
        inlineDateTimeText = FormatInlineDateTime(dt.AddMinutes(minutes));
    }

    private async Task AddInlineEntry()
    {
        var currentSelection = inlineTaskSelection;
        var dt = ParseInlineDateTimeLocal();
        var entry = new TimeEntry
        {
            Date = dt.ToString("yyyy-MM-dd"),
            StartTime = dt.ToString("HH:mm"),
            Type = inlineTaskType,
            Ticket = inlineTaskType == TaskType.Break ? null : (string.IsNullOrWhiteSpace(inlineTicket) ? null : inlineTicket),
            Description = inlineDescription,
            DayTargetHhmm = AppState.Settings.DefaultTargetHours,
            PendingForJiraSubmission = true
        };

        // Keep the selected category/subcategory (task selection) after adding.
        ApplyInlineTaskSelection(currentSelection);
        _shouldScroll = true;
        await AppState.AddNewEntryAsync(entry);
    }

    private async Task HandleInlineKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddInlineEntry();
        }
    }

    private void StartEdit(TimeEntry entry)
    {
        showEstimatedEndForEditingEntry = IsLatestEntry(entry);
        editingEntry = new TimeEntry
        {
            Id = entry.Id,
            Date = entry.Date,
            StartTime = entry.StartTime,
            Type = entry.Type,
            Ticket = entry.Ticket,
            Description = entry.Description,
            DayAccumulatedHhmm = entry.DayAccumulatedHhmm,
            DayAccumulatedDays = entry.DayAccumulatedDays,
            DayTargetHhmm = entry.DayTargetHhmm,
            DayDeviationHhmm = entry.DayDeviationHhmm,
            DayDeviationDays = entry.DayDeviationDays,
            PendingForJiraSubmission = entry.PendingForJiraSubmission
        };
        showEditDialog = true;
    }

    private async Task SaveEntry(TimeEntry entry)
    {
        await AppState.UpdateEntryAsync(entry);
        showEditDialog = false;
        showEstimatedEndForEditingEntry = false;
    }

    private async Task SavePending(TimeEntry entry)
    {
        await DebugLogAsync(
            $"SavePending invoked. id={entry.Id}, date={entry.Date}, type={entry.Type}, ticket='{entry.Ticket}', pending={entry.PendingForJiraSubmission}");
        await AppState.UpdateEntryAsync(entry);
    }

    private async Task DeleteEntry(int id)
    {
        await AppState.DeleteEntryAsync(id);
        showEditDialog = false;
        showEstimatedEndForEditingEntry = false;
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
        showEstimatedEndForEditingEntry = false;
    }

    private async Task HandleEstimatedEndSelected(DateTime? estimatedEnd)
    {
        if (estimatedEnd.HasValue)
        {
            await AppState.SetSnooze(estimatedEnd.Value);
        }
        showEditDialog = false;
        showEstimatedEndForEditingEntry = false;
    }

    private bool IsLatestEntry(TimeEntry entry)
    {
        var today = DateTime.Today.ToString("yyyy-MM-dd");
        
        // Only allow editing estimated end for today's entries
        if (entry.Date != today)
        {
            return false;
        }
        
        var latest = AppState.AllEntries
            .Where(e => e.Date == today)
            .OrderByDescending(e => DurationCalculator.GetStartMinutesOrMax(e.StartTime))
            .ThenByDescending(e => e.StartTime)
            .ThenByDescending(e => e.Id)
            .FirstOrDefault();
        
        return latest != null && latest.Id == entry.Id;
    }

    private void ToggleDataMenu()
    {
        showDataMenu = !showDataMenu;
    }

    private async Task ExportData()
    {
        showDataMenu = false;
        var csv = CsvExport.ExportToCsv(AppState.AllEntries, AppState.AllTaskEntries, AppState.Settings.CsvExportOldestFirst);
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"jtra-export-{DateTime.Today:yyyy-MM-dd}.csv", "text/csv", base64);
    }

    private async Task ImportData(ChangeEventArgs e)
    {
        showDataMenu = false;
        var fileContent = await JS.InvokeAsync<string>("readFileContentFromInput", fileInput);
        if (string.IsNullOrEmpty(fileContent)) return;
        var entries = CsvExport.ImportFromCsv(fileContent);
        foreach (var entry in entries)
        {
            await AppState.AddNewEntryAsync(entry);
        }
    }

    private async Task ClearAllData()
    {
        showDataMenu = false;
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to clear all data? This cannot be undone.");
        if (confirmed)
        {
            await IndexedDb.ClearAllDataAsync();
            await AppState.RefreshEntriesAsync();
        }
    }

    private async Task SubmitPendingTasks()
    {
        showDataMenu = false;

        await DebugLogAsync($"SubmitPendingTasks started. totalEntries={AppState.AllEntries.Count}");

        Logger.LogInformation(
            "SubmitPendingTasks started. totalEntries={TotalEntries}",
            AppState.AllEntries.Count);
        await DebugLogAsync($"All entries snapshot: {DescribeEntries(AppState.AllEntries)}");

        if (string.IsNullOrEmpty(AppState.Settings.JiraBaseUrl) || string.IsNullOrEmpty(AppState.Settings.Pat))
        {
            await DebugLogAsync("SubmitPendingTasks aborted: JiraBaseUrl or PAT missing.");
            Logger.LogWarning("SubmitPendingTasks aborted because JiraBaseUrl or PAT is missing.");
            await JS.InvokeVoidAsync("alert", "Please configure JIRA URL and PAT in Settings first.");
            return;
        }

        var selectedPendingEntries = AppState.AllEntries
            .Where(e => e.PendingForJiraSubmission)
            .ToList();

        Logger.LogInformation(
            "Selected pending entries found: {Count}. Sample: {Sample}",
            selectedPendingEntries.Count,
            string.Join(" | ", selectedPendingEntries.Take(5).Select(e =>
                $"id={e.Id},date={e.Date},type={e.Type},ticket='{e.Ticket}',pending={e.PendingForJiraSubmission}")));
        await DebugLogAsync($"Selected pending entries count={selectedPendingEntries.Count}");

        var pendingEntries = AppState.AllEntries
            .Where(e => e.PendingForJiraSubmission && IsJiraSubmittable(e))
            .ToList();

        Logger.LogInformation(
            "Pending entries selected for submission after ticket filter: {Count}. Sample: {Sample}",
            pendingEntries.Count,
            string.Join(" | ", pendingEntries.Take(5).Select(e =>
                $"id={e.Id},date={e.Date},type={e.Type},ticket='{e.Ticket}'")));
        await DebugLogAsync($"Pending entries selected for submission after ticket filter count={pendingEntries.Count}");

        if (!pendingEntries.Any())
        {
            var missingTicketCount = selectedPendingEntries.Count(e => string.IsNullOrWhiteSpace(e.Ticket));
            Logger.LogWarning(
                "No pending entries to submit. selectedPending={SelectedPending}, missingTicket={MissingTicket}",
                selectedPendingEntries.Count,
                missingTicketCount);
            await DebugLogAsync($"No pending entries to submit. selectedPending={selectedPendingEntries.Count}, missingTicket={missingTicketCount}");
            if (selectedPendingEntries.Any() && missingTicketCount == selectedPendingEntries.Count)
            {
                await JS.InvokeVoidAsync("alert", "No pending entries with a JIRA ticket to submit.");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "No pending entries to submit.");
            }
            return;
        }

        submitting = true;
        try
        {
            var grouped = GroupEntries(pendingEntries);
            int successCount = 0;
            int failCount = 0;

            foreach (var group in grouped)
            {
                var totalSeconds = group.Entries.Sum(e => DurationCalculator.CalculateDurationMinutes(AppState.AllEntries, e) * 60);
                if (totalSeconds <= 0)
                {
                    await DebugLogAsync($"Skipping group with zero duration. ticket={group.Ticket}, entries={group.Entries.Count}");
                    Logger.LogWarning(
                        "Skipping group due to zero duration. ticket={Ticket}, entries={Entries}",
                        group.Ticket,
                        string.Join(" | ", group.Entries.Select(e =>
                            $"id={e.Id},date={e.Date},start={e.StartTime},desc='{e.Description}'")));
                    failCount++;
                    continue;
                }

                var firstEntry = group.Entries.First();

                var worklog = new
                {
                    timeSpentSeconds = totalSeconds,
                    started = $"{firstEntry.Date}T{firstEntry.StartTime}:00.000+0000",
                    comment = firstEntry.Description ?? ""
                };

                try
                {
                    Logger.LogInformation(
                        "Submitting worklog. ticket={Ticket}, totalSeconds={TotalSeconds}, started={Started}, entriesInGroup={EntriesInGroup}",
                        group.Ticket,
                        totalSeconds,
                        worklog.started,
                        group.Entries.Count);
                    await DebugLogAsync($"Submitting worklog. ticket={group.Ticket}, totalSeconds={totalSeconds}, started={worklog.started}, entries={group.Entries.Count}");

                    var request = new HttpRequestMessage(HttpMethod.Post, $"/api/jira/issue/{group.Ticket}/worklog");
                    request.Headers.Add("X-Jira-Base-Url", AppState.Settings.JiraBaseUrl);
                    request.Headers.Add("X-Jira-Pat", AppState.Settings.Pat);
                    request.Content = JsonContent.Create(worklog);

                    var response = await Http.SendAsync(request);

                    if (response.IsSuccessStatusCode)
                    {
                        await DebugLogAsync($"Worklog submit succeeded. ticket={group.Ticket}");
                        Logger.LogInformation("Worklog submit succeeded. ticket={Ticket}", group.Ticket);
                        foreach (var entry in group.Entries)
                        {
                            entry.PendingForJiraSubmission = false;
                            await IndexedDb.UpdateTimeEntryAsync(entry);
                        }
                        successCount++;
                    }
                    else
                    {
                        var errorBody = await response.Content.ReadAsStringAsync();
                        await DebugLogAsync($"Worklog submit failed. ticket={group.Ticket}, status={(int)response.StatusCode}, body={errorBody}");
                        Logger.LogWarning(
                            "Worklog submit failed. ticket={Ticket}, status={StatusCode}, body={Body}",
                            group.Ticket,
                            (int)response.StatusCode,
                            errorBody);
                        failCount++;
                    }
                }
                catch (Exception ex)
                {
                    await DebugLogAsync($"Worklog submit exception. ticket={group.Ticket}, ex={ex.Message}");
                    Logger.LogError(ex, "Worklog submit threw exception. ticket={Ticket}", group.Ticket);
                    failCount++;
                }
            }

            await AppState.RefreshEntriesAsync();
            Logger.LogInformation("SubmitPendingTasks finished. success={SuccessCount}, failed={FailCount}", successCount, failCount);
            await DebugLogAsync($"SubmitPendingTasks finished. success={successCount}, failed={failCount}");
            await JS.InvokeVoidAsync("alert", $"Submitted {successCount} worklogs. Failed: {failCount}");
        }
        finally
        {
            submitting = false;
        }
    }

    private ValueTask DebugLogAsync(string message)
    {
        Logger.LogInformation("[SubmitPendingTasks] {Message}", message);
        return JS.InvokeVoidAsync("console.log", $"[JTRA] {message}");
    }

    private List<(string Ticket, List<TimeEntry> Entries)> GroupEntries(List<TimeEntry> entries)
    {
        var result = new List<(string, List<TimeEntry>)>();
        var sorted = entries.OrderBy(e => e.Date).ThenBy(e => e.StartTime).ToList();

        List<TimeEntry>? currentGroup = null;
        string? currentTicket = null;
        string? currentDescription = null;
        string? currentDate = null;

        foreach (var entry in sorted)
        {
            if (currentGroup == null || entry.Ticket != currentTicket || entry.Description != currentDescription || entry.Date != currentDate)
            {
                if (currentGroup != null)
                {
                    result.Add((currentTicket!, currentGroup));
                }
                currentGroup = new List<TimeEntry> { entry };
                currentTicket = entry.Ticket;
                currentDescription = entry.Description;
                currentDate = entry.Date;
            }
            else
            {
                currentGroup.Add(entry);
            }
        }

        if (currentGroup != null)
        {
            result.Add((currentTicket!, currentGroup));
        }

        return result;
    }

    private static bool IsJiraSubmittable(TimeEntry entry)
    {
        return !string.IsNullOrWhiteSpace(entry.Ticket);
    }

    private (string Category, string Subcategory) GetEntryLabels(TimeEntry entry)
    {
        if (entry.Type == TaskType.Break)
            return ("Break", string.Empty);

        var entryTicket = Normalize(entry.Ticket);
        var entryDescription = Normalize(entry.Description);

        // 1) Prefer exact ticket+description match.
        var task = AppState.AllTaskEntries.FirstOrDefault(t =>
            string.Equals(Normalize(t.Ticket), entryTicket, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(Normalize(t.Description), entryDescription, StringComparison.OrdinalIgnoreCase));

        // 2) Fallback: match by ticket only.
        task ??= AppState.AllTaskEntries.FirstOrDefault(t =>
            !string.IsNullOrEmpty(entryTicket) &&
            string.Equals(Normalize(t.Ticket), entryTicket, StringComparison.OrdinalIgnoreCase));

        // 3) Fallback: match by description only.
        task ??= AppState.AllTaskEntries.FirstOrDefault(t =>
            !string.IsNullOrEmpty(entryDescription) &&
            string.Equals(Normalize(t.Description), entryDescription, StringComparison.OrdinalIgnoreCase));

        if (task != null)
        {
            return (task.Category ?? string.Empty, task.Subcategory ?? string.Empty);
        }

        // Avoid showing hardcoded "Ticket" when no task metadata can be resolved.
        var category = entry.Type == TaskType.Ticket ? string.Empty : entry.Type.ToString();
        return (category, string.Empty);
    }

    private static string Normalize(string? value)
    {
        return (value ?? string.Empty).Trim();
    }

    private static string DescribeEntries(IEnumerable<TimeEntry> entries)
    {
        var list = entries
            .OrderBy(e => e.Date)
            .ThenBy(e => e.StartTime)
            .Select(e =>
                $"id={e.Id},date={e.Date},start={e.StartTime},type={e.Type},ticket='{e.Ticket}',pending={e.PendingForJiraSubmission}")
            .ToList();

        return list.Count == 0 ? "<none>" : string.Join(" || ", list);
    }

    private DateTime ParseInlineDateTimeLocal()
    {
        if (!string.IsNullOrWhiteSpace(inlineDateTimeText))
        {
            var parts = inlineDateTimeText.Split(' ');
            if (parts.Length == 2)
            {
                var dateParts = parts[0].Split('.');
                var timeParts = parts[1].Split(':');

                if (dateParts.Length == 3 && timeParts.Length >= 2 &&
                    int.TryParse(dateParts[0], out var year) &&
                    int.TryParse(dateParts[1], out var month) &&
                    int.TryParse(dateParts[2], out var day) &&
                    int.TryParse(timeParts[0], out var hour) &&
                    int.TryParse(timeParts[1], out var minute))
                {
                    try
                    {
                        return new DateTime(year, month, day, hour, minute, 0);
                    }
                    catch
                    {
                        // Fall through to fallback rounding
                    }
                }
            }
        }

        var fallback = RoundToNearest5(DateTime.Now);
        inlineDateTimeText = FormatInlineDateTime(fallback);
        return fallback;
    }

    private static string FormatInlineDateTime(DateTime dt)
    {
        return dt.ToString("yyyy.MM.dd HH:mm");
    }

    private static string FormatDateTime(string? date, string? time)
    {
        if (string.IsNullOrEmpty(date) || string.IsNullOrEmpty(time)) return string.Empty;
        var dp = date.Split('-');
        var tp = time.Split(':');
        if (dp.Length >= 3 && tp.Length >= 2)
            return $"{dp[0]}.{dp[1]}.{dp[2]} {tp[0]}:{tp[1]}";
        return $"{date} {time}";
    }

    private static string FormatTaskOption(TaskEntry task)
    {
        var category = task.Category;
        var subcategory = string.IsNullOrWhiteSpace(task.Subcategory) ? string.Empty : $" / {task.Subcategory}";
        var ticket = string.IsNullOrWhiteSpace(task.Ticket) ? string.Empty : $" ({task.Ticket})";
        return $"{category}{subcategory}{ticket}";
    }

    private static DateTime RoundToNearest5(DateTime dt)
    {
        var minutes = ((dt.Minute + 4) / 5) * 5;
        var rounded = new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0).AddMinutes(minutes);
        return rounded;
    }

}
