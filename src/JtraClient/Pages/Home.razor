@page "/"
@implements IDisposable

<PageTitle>JTRA - Home</PageTitle>

<div class="today-stats">
    <div class="stat-card">
        <h3>Target</h3>
        <span class="stat-value">@AppState.TodayTarget.ToString(@"hh\:mm")</span>
    </div>
    <div class="stat-card">
        <h3>Logged</h3>
        <span class="stat-value">@AppState.TodayAccumulated.ToString(@"hh\:mm")</span>
    </div>
    <div class="stat-card @(AppState.TodayDeviation.TotalMinutes < 0 ? "negative" : "positive")">
        <h3>Deviation</h3>
        <span class="stat-value">@AppState.TodayDeviation.ToString(@"hh\:mm")</span>
    </div>
</div>

<div class="entries-header">
    <div class="date-navigation">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousDay">&lt;</button>
        <input type="date" @bind="selectedDate" @bind:format="yyyy-MM-dd" class="form-control form-control-sm date-picker" />
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextDay">&gt;</button>
        @if (selectedDate.Date != DateTime.Today)
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="GoToToday">Today</button>
        }
    </div>
    <button class="btn btn-primary" @onclick="ShowNewEntryDialog">Add Entry</button>
</div>

@if (DisplayedEntries.Any())
{
    <div class="entries-list">
        @foreach (var entry in DisplayedEntries.OrderByDescending(e => e.StartTime))
        {
            <div class="entry-row" @ondblclick="() => StartEdit(entry)">
                <div class="entry-time">@FormatTime(entry.StartTime)</div>
                <div class="entry-type @entry.Type.ToString().ToLower()">@entry.Type</div>
                <div class="entry-ticket">@entry.Ticket</div>
                <div class="entry-description">@entry.Description</div>
                <div class="entry-duration">@FormatTime(entry.Duration)</div>
                <div class="entry-actions">
                    @if (!string.IsNullOrEmpty(entry.Ticket) && !entry.SubmittedToJira)
                    {
                        <span class="badge bg-warning">Pending</span>
                    }
                    else if (entry.SubmittedToJira)
                    {
                        <span class="badge bg-success">Submitted</span>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="no-entries">No entries for @selectedDate.ToString("ddd, MMM d, yyyy").</p>
}

@if (showEditDialog && editingEntry != null)
{
    <EditEntryDialog Entry="editingEntry" OnSave="SaveEntry" OnDelete="DeleteEntry" OnClose="CloseEditDialog" />
}

@code {
    [Inject] private AppState AppState { get; set; } = default!;

    private bool showEditDialog = false;
    private TimeEntry? editingEntry;
    private DateTime selectedDate = DateTime.Today;

    private IEnumerable<TimeEntry> DisplayedEntries => selectedDate.Date == DateTime.Today 
        ? AppState.TodayEntries 
        : AppState.AllEntries.Where(e => e.Date == selectedDate.ToString("yyyy-MM-dd"));

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void PreviousDay()
    {
        selectedDate = selectedDate.AddDays(-1);
    }

    private void NextDay()
    {
        selectedDate = selectedDate.AddDays(1);
    }

    private void GoToToday()
    {
        selectedDate = DateTime.Today;
    }

    private void ShowNewEntryDialog()
    {
        selectedDate = DateTime.Today;
        AppState.ShowAddEntryPopup();
    }

    private void StartEdit(TimeEntry entry)
    {
        editingEntry = new TimeEntry
        {
            Id = entry.Id,
            Date = entry.Date,
            StartTime = entry.StartTime,
            Type = entry.Type,
            Ticket = entry.Ticket,
            Description = entry.Description,
            Duration = entry.Duration,
            DayAccumulatedHhmm = entry.DayAccumulatedHhmm,
            DayAccumulatedDays = entry.DayAccumulatedDays,
            DayTargetHhmm = entry.DayTargetHhmm,
            DayDeviationHhmm = entry.DayDeviationHhmm,
            DayDeviationDays = entry.DayDeviationDays,
            SubmittedToJira = entry.SubmittedToJira
        };
        showEditDialog = true;
    }

    private async Task SaveEntry(TimeEntry entry)
    {
        await AppState.UpdateEntryAsync(entry);
        showEditDialog = false;
    }

    private async Task DeleteEntry(int id)
    {
        await AppState.DeleteEntryAsync(id);
        showEditDialog = false;
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
    }

    private static string FormatTime(string? time)
    {
        if (string.IsNullOrEmpty(time)) return string.Empty;
        var parts = time.Split(':');
        if (parts.Length >= 2)
            return $"{parts[0]}:{parts[1]}";
        return time;
    }
}
